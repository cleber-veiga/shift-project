# ── Banco de Dados da Plataforma (asyncpg) ──
DATABASE_URL=postgresql+asyncpg://shift:shift@localhost:5432/shift

# ── Segurança / JWT ──
SECRET_KEY=troque-por-uma-chave-secreta-forte
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Logging ──
# LOG_FORMAT: "console" (dev, colorido) ou "json" (producao, structured logs)
# LOG_LEVEL:  DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=console
LOG_LEVEL=INFO

# ── Rate Limiting ──
# Armazenamento do slowapi. "memory://" para 1 replica; redis://host:port/db
# para multi-replica com contagem compartilhada.
RATE_LIMIT_STORAGE_URI=memory://

# ── dlt ──
DLT_DEFAULT_DESTINATION=postgres
