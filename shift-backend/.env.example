# shift-backend — variaveis para rodar o backend STANDALONE (sem Docker).
#
# IMPORTANTE: este arquivo SO e usado quando voce roda o backend direto
# (ex: `cd shift-backend && uvicorn main:app`). No fluxo Docker Compose
# normal, todas as variaveis vem do .env da RAIZ do projeto, injetadas
# via `environment:` do docker-compose.yml — este arquivo e ignorado.
#
# Workflow standalone:
#   cp .env.example .env
#   # editar .env com valores (DATABASE_URL apontando pro banco em nuvem)
#   uvicorn main:app --reload
#
# Single source of truth e o ../env.example da raiz. As variaveis abaixo
# sao um SUBCONJUNTO daquelas que o backend consome — nao adicione
# variaveis exclusivas aqui, ou voce vai criar divergencia.

# === Banco de dados ==========================================================
# Use ?sslmode=require em qualquer banco em nuvem.
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/DB?sslmode=require

# === Auth / Crypto ===========================================================
# SECRET_KEY (JWT):
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ENCRYPTION_KEY (Fernet, 44 chars base64):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=__GENERATE_ME__
ENCRYPTION_KEY=__GENERATE_ME__
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Logging =================================================================
# LOG_FORMAT: 'console' (dev colorido) ou 'json' (prod)
# LOG_LEVEL:  DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console
LOG_LEVEL=DEBUG

# === URLs publicas ===========================================================
FRONTEND_BASE_URL=http://localhost:3000
EXTERNAL_BASE_URL=http://localhost:8000

# === Sandbox =================================================================
# Standalone tipicamente NAO tem docker disponivel — desligue o sandbox.
SANDBOX_ENABLED=false

# === Tracing =================================================================
# Em standalone, tracing exige um collector OTLP rodando — desligue se
# nao tiver, ou aponte pro otel-collector do compose.
SHIFT_TRACING_ENABLED=false

# === Webhooks ================================================================
# Em dev local, true permite webhooks pra hosts privados. Em prod NUNCA.
WEBHOOK_ALLOW_INSECURE_HOSTS=true

# === LLM =====================================================================
LLM_MODEL=anthropic/claude-sonnet-4-20250514
LLM_API_KEY=

# === LangSmith (opcional) ====================================================
# LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=shift-platform-agent

# === dlt =====================================================================
DLT_DEFAULT_DESTINATION=postgres
