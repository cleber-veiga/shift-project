# ============================================================================
# PROPOSITO:    Backend rodando STANDALONE (sem Docker, com `uvicorn`).
# AUDIENCIA:    Desenvolvedor da Shift debugando so o backend.
# LIDO POR:     pydantic-settings em app/core/config.py.
# ARQUIVO REAL: shift-backend/.env (gitignore).
#
# Visao geral de TODOS os arquivos .env*: ../docs/configuration.md
# ============================================================================
#
# Workflow:
#   cd shift-backend
#   cp .env.example .env
#   # editar .env (DATABASE_URL, SECRET_KEY, ENCRYPTION_KEY)
#   uvicorn main:app --reload
#
# Este arquivo e IGNORADO no fluxo Docker — o compose injeta env vars
# diretamente. Aqui ficam apenas as variaveis que o backend consome
# quando rodado fora do container.

# === Database ================================================================
# Mesmo formato do .env da raiz. Use ?sslmode=require em qualquer cloud.
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/DB?sslmode=require

# === Auth / Crypto ===========================================================
# Em standalone NAO ha bootstrap-secrets — gere manualmente uma vez:
#   SECRET_KEY:     python -c "import secrets; print(secrets.token_urlsafe(64))"
#   ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=__GENERATE_ME__
ENCRYPTION_KEY=__GENERATE_ME__
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Logging =================================================================
LOG_FORMAT=console
LOG_LEVEL=DEBUG

# === URLs publicas ===========================================================
FRONTEND_BASE_URL=http://localhost:3000
EXTERNAL_BASE_URL=http://localhost:8000

# === Sandbox (desligar em standalone — nao tem docker.sock acessivel) ========
SANDBOX_ENABLED=false

# === Tracing (desligar — sem otel-collector local) ===========================
SHIFT_TRACING_ENABLED=false

# === Webhooks (dev permite hosts privados; em prod NUNCA) ====================
WEBHOOK_ALLOW_INSECURE_HOSTS=true

# === LLM =====================================================================
# Em standalone nao ha embedded.env — set manualmente sua chave.
LLM_MODEL=anthropic/claude-sonnet-4-20250514
LLM_API_KEY=

# === dlt =====================================================================
DLT_DEFAULT_DESTINATION=postgres
