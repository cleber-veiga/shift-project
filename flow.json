    {
      "id": "node_1776266083668_2",
      "data": {
        "type": "sql_database",
        "label": "SQL: Consulta Clientes e Fornecedores",
        "query": "SELECT\n\tCLI.CODIGO,\n\t'N' AS EHREPRESENTANTE,\n\tCASE \n\t\tWHEN CLI.TIPO IN ('C','U') THEN 'S' \n\t\tELSE 'N' \n\tEND AS EHCLIENTE,\n\tCASE \n\t\tWHEN CLI.TIPO = 'F' THEN 'S' \n\t\tELSE 'N' \n\tEND AS EHFORNECEDOR,\t\n\tCASE WHEN CLI.TIPO = 'T' THEN 'S' \n\t\tELSE 'N' \n\tEND AS EHTRANSPORTADOR,\n\t'N' AS EHFUNCIONARIO,\n    CLI.NOME,\n    CLI.CNPJ,\n\tCLI.FANTASIA,\n\tCASE \n\t\tWHEN CLI.FISICAJURIDICA = 'J' THEN CLI.INSCRICAO \n\t\tELSE NULL \n\tEND AS INSCEST,\n\tCASE \n\t\tWHEN CLI.FISICAJURIDICA = 'F' THEN CLI.INSCRICAO \n\t\tELSE '' \n\tEND AS RG,\n\tCASE \n\t\tWHEN (CLI.FISICAJURIDICA = 'J') AND ((CLI.INSCRICAO<>'') OR (CLI.INSCRICAO<>'ISENTO')) THEN 2\n\t\tWHEN (CLI.FISICAJURIDICA = 'J') AND ((CLI.INSCRICAO='') OR (CLI.INSCRICAO='ISENTO')) THEN 1\n\t\tWHEN CLI.FISICAJURIDICA = 'F' THEN 1 \n\t\tELSE 1\n\tEND AS IDTIPOPESSOA,\n    CLI.EMAIL,\n    CLI.EMAILNFE,\n\tCASE \n\t\tWHEN CAST(CLI.DATAALTERACAO AS DATE) IS NULL THEN CAST(GETDATE() AS date) \n\t\tELSE CAST(CLI.DATAALTERACAO AS DATE) \n\tEND AS DTCADASTRO,\n\tCASE \n\t\tWHEN CLI.INATIVO = 1 THEN CAST(GETDATE() AS date) \n\t\tELSE NULL \n\tEND AS DTINATIVO,\n    CASE \n\t\tWHEN CLI.SEXO = 1 THEN 'M' \n\t\tELSE 'F' \n\tEND AS SEXO,\n    CAST(CLI.NASCIMENTO AS DATE) AS DTNASC,\n\tCLI.SALARIO,\n\tCLI.OBS,\n    CASE \n\t\tWHEN CLI.LIMITE_CREDITO = 999999.99 THEN NULL \n\t\tELSE CLI.LIMITE_CREDITO \n\tEND AS LIMITE,\n    CASE \n\t\tWHEN CLI.LIMITE_CREDITO = 999999.99 THEN NULL \n\t\tELSE CLI.LIMITE_CREDITO \n\tEND AS LIMITEMENSAL,\n    CLI.CONTATO,\n    CLI.ENDERECO, \n    CLI.COMPLEMENTO,\n    CLI.NUMERO, \n    CLI.CIDADE, \n    CLI.UF, \n    CLI.CEP, \n\tCLI.FONE1, \n\tCLI.FONE2, \n\tCLI.FAX, \n\tCLI.BAIRRO   \nFROM CLI_FOR CLI \nWHERE CLI.TIPO IN ('C','U','T','F')",
        "chunk_size": 1000,
        "connection_id": "589771f0-17af-4e9c-9e57-8c5efdcf338e",
        "saved_query_id": "1e9ae50e-6736-4a2d-a5e7-7083de584587",
        "connection_name": "Conexão ETrade"
      },
