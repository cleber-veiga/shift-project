# ============================================================================
# Shift — variaveis de ambiente para teste local
# ============================================================================
# Copie este arquivo para .env e preencha os valores marcados com __FILL_ME__.
# Os valores ja preenchidos podem ser mantidos como estao.
# ============================================================================

# --- Banco de dados (fornecido) ---------------------------------------------
# Recebido do Cleber. Formato:
#   postgresql+asyncpg://USER:PASS@HOST:5432/DB?sslmode=require
DATABASE_URL=__FILL_ME__

# --- Chaves de criptografia (gerar antes do primeiro `up`) -------------------
# SECRET_KEY (JWT) — qualquer string aleatoria longa. Gere com:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=__FILL_ME__

# ENCRYPTION_KEY (Fernet, 44 chars base64). Gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Se nao tiver Python a mao, use Docker:
#   docker run --rm python:3.12-slim python -c "from cryptography.fernet import Fernet; import subprocess; subprocess.run(['pip','install','-q','cryptography']); print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=__FILL_ME__

# --- Logs --------------------------------------------------------------------
LOG_FORMAT=console
LOG_LEVEL=INFO

# --- LLM (opcional — preencha se for testar features de IA) ------------------
# Formato LiteLLM. Exemplos:
#   anthropic/claude-sonnet-4-20250514   (precisa ANTHROPIC_API_KEY)
#   openai/gpt-4o-mini                    (precisa OPENAI_API_KEY)
LLM_MODEL=anthropic/claude-sonnet-4-20250514
LLM_API_KEY=
AGENT_ENABLED=false

# --- Google OAuth (opcional) -------------------------------------------------
GOOGLE_CLIENT_ID=

# --- Linux/WSL2 apenas: GID do grupo `docker` no host ------------------------
# Descobrir: `getent group docker | cut -d: -f3`
# No Docker Desktop (Windows/macOS) pode deixar como esta.
DOCKER_GID=999
