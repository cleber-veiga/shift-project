# ============================================================================
# PROPOSITO:    Configuracao do pacote de teste do Shift (cliente final).
# AUDIENCIA:    Tester / cliente recebendo o produto.
# LIDO POR:     docker-compose.yml deste pacote (`docker compose up`).
# ARQUIVO REAL: .env (criado pelo tester).
#
# Suporte: README.md neste mesmo diretorio.
# ============================================================================
#
# Workflow:
#   cp .env.example .env
#   # editar DATABASE_URL com a string que voce recebeu
#   docker compose pull
#   docker compose up -d
#
# As chaves de criptografia (SECRET_KEY/ENCRYPTION_KEY) sao geradas
# AUTOMATICAMENTE no primeiro `up` e persistidas em volume Docker. Voce
# nao precisa gerar nada.

# === Banco de dados (OBRIGATORIO) ============================================
# String recebida do Cleber. Formato:
#   postgresql+asyncpg://USER:PASS@HOST:5432/DB?sslmode=require
DATABASE_URL=__FILL_ME__

# === Logs ====================================================================
LOG_FORMAT=console
LOG_LEVEL=INFO

# === Linux/WSL2 — GID do grupo `docker` no host ==============================
# Descobrir: getent group docker | cut -d: -f3
# Docker Desktop (Win/macOS): manter como esta.
DOCKER_GID=999

# === Firebird bundled (Cenario A — opcional) =================================
# So preencher se voce vai usar o Cenario A: tem so o arquivo .fdb e quer
# que a Shift suba os servidores Firebird 2.5/3.0 em containers.
#
# Cenario B (FB no host Windows) e Cenario C (FB remoto): pode IGNORAR
# essas variaveis.
#
# Para Cenario A:
#   1) Crie a pasta no host (ex: C:\Shift\Data ou /opt/shift/data)
#   2) Copie os arquivos .fdb dos clientes para essa pasta
#   3) Aponte FIREBIRD_LEGACY_DATA_DIR para ela
#   4) Suba com: docker compose --profile firebird-legacy up -d
#
# No UI da Shift, ao criar a Connection, use:
#   host = firebird25  (ou firebird30, conforme o ODS do .fdb)
#   port = 3050
#   path = /firebird/data/<nome>.FDB
#
# FIREBIRD_LEGACY_DATA_DIR=C:/Shift/Data
# FIREBIRD_LEGACY_PASSWORD=masterkey
