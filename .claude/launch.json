{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "shift-frontend", "run", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "docs",
      "runtimeExecutable": "mkdocs",
      "runtimeArgs": ["serve", "-a", "127.0.0.1:8001"],
      "port": 8001,
      "autoPort": false
    }
  ]
}
