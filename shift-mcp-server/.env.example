# ============================================================================
# PROPOSITO:    Configuracao do MCP Server da Shift (Claude Desktop, n8n, etc).
# AUDIENCIA:    Cliente final integrando o Shift via Model Context Protocol.
# LIDO POR:     shift-mcp-server (entrypoint do MCP).
# ARQUIVO REAL: .env (gitignore).
#
# Visao geral de TODOS os arquivos .env*: ../docs/configuration.md
# ============================================================================

# === Backend Shift ===========================================================
# URL base do backend Shift (inclui /api/v1).
SHIFT_BACKEND_URL=https://shift.example.com/api/v1

# === Autenticacao ============================================================
# Bearer key gerada em /espaco/<workspace>/api-keys (so e exibida 1 vez).
# Formato: sk_shift_<48 chars urlsafe>.
SHIFT_API_KEY=sk_shift_CHANGEME

# === Transporte ==============================================================
# stdio           -> Claude Desktop
# streamable-http -> n8n / Docker / outras integracoes
SHIFT_MCP_TRANSPORT=stdio

# Apenas para streamable-http:
SHIFT_MCP_HOST=127.0.0.1
SHIFT_MCP_PORT=8765

# === Politicas (segundos) ====================================================
SHIFT_MCP_APPROVAL_POLL_INTERVAL=2.0
SHIFT_MCP_APPROVAL_TIMEOUT=300
SHIFT_MCP_REQUEST_TIMEOUT=30
