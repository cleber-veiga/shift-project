{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "Shift — Execution Health",
  "uid": "shift-exec-health",
  "tags": ["shift"],
  "timezone": "browser",
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "Prometheus"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Duracao de execucao (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {
          "expr": "shift:execution_duration:p50:5m:global",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "shift:execution_duration:p95:5m:global",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "shift:execution_duration:p99:5m:global",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "description": "Usa recording rules pre-agregadas (shift:execution_duration:*:global) quando disponiveis. Fallback automatico nao implementado — caso recording rules estejam desativadas, edite os queries para usar histogram_quantile diretamente."
    },
    {
      "id": 2,
      "title": "Success rate (5min)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.9},
              {"color": "green", "value": 0.95}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(shift_executions_total{status=\"completed\"}[5m])) / clamp_min(sum(rate(shift_executions_total[5m])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Erros por minuto (por status)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {
          "expr": "sum by (status) (rate(shift_executions_total{status!=\"completed\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Throughput de execucoes",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {
          "expr": "sum by (status) (rate(shift_executions_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Erros por classe (nodes)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {
          "expr": "sum by (error_class) (rate(node_errors_total[5m]))",
          "legendFormat": "{{error_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Top tipos de no por duracao p95",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 16},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, node_type) (rate(node_duration_seconds_bucket[15m]))))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Linhas processadas (in/out por tipo de no)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 16},
      "fieldConfig": {"defaults": {"unit": "rows/s"}},
      "targets": [
        {
          "expr": "sum by (node_type, direction) (rate(node_rows_processed[5m]))",
          "legendFormat": "{{node_type}} ({{direction}})",
          "refId": "A"
        }
      ]
    }
  ]
}
