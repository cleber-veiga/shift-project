# Shift — single source of truth de variaveis de ambiente.
#
# Este arquivo e a referencia canonica. Todo o stack Docker Compose le daqui.
# Os arquivos shift-backend/.env.example e shift-frontend/.env.example existem
# apenas para documentar quais variaveis cada app consome quando rodada
# standalone (uvicorn / pnpm dev fora do Docker) — sao SUBCONJUNTOS deste,
# nao adicionam variaveis novas.
#
# Workflow:
#   cp .env.example .env       # copia template
#   # edita .env com valores reais
#   make build && make up      # Docker le este .env
#
# Para rodar standalone (sem Docker), ver shift-backend/.env.example e
# shift-frontend/.env.example com instrucoes especificas.
#
# Geracao de chaves:
#   SECRET_KEY (JWT):
#     python -c "import secrets; print(secrets.token_urlsafe(64))"
#   ENCRYPTION_KEY (Fernet, 44 chars base64):
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Tags por consumidor:
#   [B] = backend     [F] = frontend     [I] = infra (compose, prometheus, grafana)

# === [B] Database (Postgres em NUVEM) ========================================
# OBRIGATORIO. O banco NAO sobe localmente — use Neon, Supabase, AWS RDS,
# GCP Cloud SQL, Azure Database for PostgreSQL, etc.
#
# Formato (asyncpg + alembic, SSL obrigatorio em quase todo cloud):
#   postgresql+asyncpg://USER:PASS@HOST:5432/DB?sslmode=require
#
# IMPORTANTE: use ?sslmode=require (NAO ?ssl=require). SQLAlchemy traduz
# para asyncpg em runtime e para psycopg2 em alembic — ambos respeitam
# sslmode=require. Misturar formatos quebra alembic ou o boot.
#
# Bootstrap pre-execucao (uma unica vez, no banco da nuvem):
#   1) CREATE EXTENSION IF NOT EXISTS pgcrypto;
#      (necessario por compatibilidade com migrations que usam
#      gen_random_uuid(); em PG13+ ja vem no core, mas a extensao
#      precisa estar instalada se o cluster for stricto)
#   Veja ops/postgres/bootstrap.sql.
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/DB?sslmode=require

# === [I] Portas expostas no host =============================================
BACKEND_PORT=8000
FRONTEND_PORT=3000
# Grafana usa 3001 pra nao colidir com o frontend (3000)
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090

# === [B] Logging ==============================================================
# LOG_FORMAT: 'console' (dev colorido) ou 'json' (prod)
# LOG_LEVEL:  DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json
LOG_LEVEL=INFO

# === [B] Auth / Crypto (OBRIGATORIAS — gerar conforme cabecalho) =============
SECRET_KEY=__GENERATE_ME__
ENCRYPTION_KEY=__GENERATE_ME__
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === [F] URL da API — burned no build do Next.js =============================
# IMPORTANTE: o codigo do frontend usa NEXT_PUBLIC_API_BASE_URL com sufixo
# /api/v1 (ver shift-frontend/lib/auth.ts e similares). Trocar antes de
# rebuild em prod.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# === [B] URLs publicas usadas pelo backend ===================================
# FRONTEND_BASE_URL: usado em links de email (convites, reset de senha)
# EXTERNAL_BASE_URL: usado em URLs de webhook na UI
FRONTEND_BASE_URL=http://localhost:3000
EXTERNAL_BASE_URL=http://localhost:8000

# === [B] Email ===============================================================
# EMAIL_BACKEND: 'console' (loga no stdout) ou 'resend'
EMAIL_BACKEND=console
# RESEND_API_KEY=
# EMAIL_FROM=noreply@shift.app

# === [B] OAuth (Google) ======================================================
GOOGLE_CLIENT_ID=

# === [B] Tracing / OTel ======================================================
SHIFT_TRACING_ENABLED=true

# === [B] Sandbox (Docker code execution) =====================================
SANDBOX_ENABLED=true
SANDBOX_IMAGE=shift-kernel-runtime:latest
SANDBOX_DEFAULT_CPU_QUOTA=1.0
SANDBOX_DEFAULT_MEM_LIMIT_MB=512
SANDBOX_DEFAULT_TIMEOUT_S=60
SANDBOX_POOL_ENABLED=true
SANDBOX_POOL_TARGET_IDLE=2
SANDBOX_POOL_MAX_SIZE=8

# === [I] GID do grupo docker no host =========================================
# Linux/WSL2 default = 999.
# Descobrir com: `getent group docker | cut -d: -f3`
# No macOS/Docker Desktop normalmente nao precisa setar.
DOCKER_GID=999

# === [B] Streaming ===========================================================
STREAMING_MAX_IN_MEMORY_CHUNKS=4
STREAMING_SPILL_WHEN_EXCEEDED=true

# === [B] Webhooks ============================================================
# false = anti-SSRF estrito (recusa hosts privados). NAO mude em prod.
# O override de dev seta true automaticamente.
WEBHOOK_ALLOW_INSECURE_HOSTS=false

# === [B] LLM / Agent =========================================================
LLM_MODEL=anthropic/claude-sonnet-4-20250514
LLM_API_KEY=
AGENT_ENABLED=false
AGENT_LLM_MODEL=anthropic/claude-sonnet-4-20250514

# === [B] LangSmith (opcional) ================================================
# LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=shift-platform-agent

# === [B] dlt =================================================================
DLT_DEFAULT_DESTINATION=postgres

# === [I] Grafana =============================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_change_me

# === [I] Firebird (Cenario A — servidor bundled) =============================
# So usado quando o cliente nao tem Firebird Server e a Shift sobe FB 2.5/3.0
# em container. Para cenarios com servidor remoto (Windows host ou rede),
# essas variaveis sao IRRELEVANTES — credenciais ficam em cada Connection.
# Veja docs/firebird-deployment.md para o guia completo.
#
# Diretorio do host com os arquivos .fdb dos clientes. Sera bind-montado
# em /firebird/data nos containers firebird25/firebird30 (rw) e em
# shift-backend (ro, para auto-deteccao de ODS).
#
# CONVENCAO Shift (use sempre que possivel — wizard, docs e placeholders
# do frontend assumem esses paths):
#   Windows: C:/Shift/Data
#   Linux:   /opt/shift/data
#
# Crie a pasta antes de subir o stack:
#   mkdir C:\Shift\Data        (PowerShell)
#   sudo mkdir -p /opt/shift/data && sudo chown $USER /opt/shift/data
FIREBIRD_LEGACY_DATA_DIR=C:/Shift/Data

# Senha do SYSDBA dos servidores bundled. NAO afeta servidores remotos.
# Para subir o profile: docker compose --profile firebird-legacy up -d
FIREBIRD_LEGACY_PASSWORD=masterkey
