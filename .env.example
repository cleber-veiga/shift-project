# ============================================================================
# PROPOSITO:    Configuracao do stack Docker Compose em dev local (Shift).
# AUDIENCIA:    Desenvolvedor da Shift.
# LIDO POR:     docker-compose.yml na raiz (`docker compose up`).
# ARQUIVO REAL: .env (gitignore).
#
# Visao geral de TODOS os arquivos .env*: docs/configuration.md
# ============================================================================
#
# Workflow:
#   cp .env.example .env    # editar com valores reais
#   docker compose up -d
#
# Tags por consumidor:  [B] backend  [F] frontend  [I] infra (compose/observability)

# === [B] Database (Postgres em NUVEM — OBRIGATORIO) ==========================
# O banco NAO sobe localmente. Use Neon, Supabase, RDS, etc.
# Use SEMPRE ?sslmode=require (nao ?ssl=require).
# Bootstrap one-shot do banco: ops/postgres/bootstrap.sql (cria pgcrypto).
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/DB?sslmode=require

# === [I] Portas expostas no host =============================================
BACKEND_PORT=8000
FRONTEND_PORT=3000
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090

# === [B] Logging =============================================================
# LOG_FORMAT: console (dev) | json (prod)
# LOG_LEVEL:  DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json
LOG_LEVEL=INFO

# === [B] Auth / Crypto =======================================================
# AUTO-GERADAS no primeiro boot via bootstrap-secrets.py — deixe vazias.
# Detalhes: docs/configuration.md (secao "Segredos auto-gerados").
SECRET_KEY=
ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === [F] URL da API =========================================================
# Burned no build do Next.js. Trocar antes de rebuild em prod.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# === [B] URLs publicas usadas pelo backend ===================================
FRONTEND_BASE_URL=http://localhost:3000
EXTERNAL_BASE_URL=http://localhost:8000

# === [B] Email ===============================================================
# EMAIL_BACKEND: console (dev) | resend (prod)
# RESEND_API_KEY/EMAIL_FROM ficam EMBUTIDOS na imagem pela CI (.env.build).
# Aqui apenas para sobrescrever em dev se quiser testar com sua conta Resend.
EMAIL_BACKEND=console

# === [B] OAuth / LLM / LangSmith =============================================
# GOOGLE_CLIENT_ID, LLM_API_KEY, LANGSMITH_API_KEY ficam EMBUTIDOS na imagem
# pela CI (.env.build). NAO setar aqui em prod. Sobrescrita opcional em dev.
AGENT_ENABLED=false

# === [B] Observability =======================================================
SHIFT_TRACING_ENABLED=true

# === [B] Sandbox (Docker code execution) =====================================
SANDBOX_ENABLED=true
SANDBOX_IMAGE=shift-kernel-runtime:latest
SANDBOX_DEFAULT_CPU_QUOTA=1.0
SANDBOX_DEFAULT_MEM_LIMIT_MB=512
SANDBOX_DEFAULT_TIMEOUT_S=60
SANDBOX_POOL_ENABLED=true
SANDBOX_POOL_TARGET_IDLE=2
SANDBOX_POOL_MAX_SIZE=8

# === [B] Streaming ===========================================================
STREAMING_MAX_IN_MEMORY_CHUNKS=4
STREAMING_SPILL_WHEN_EXCEEDED=true

# === [B] Webhooks ============================================================
# false = anti-SSRF estrito. NAO mudar em prod.
WEBHOOK_ALLOW_INSECURE_HOSTS=false

# === [B] dlt =================================================================
DLT_DEFAULT_DESTINATION=postgres

# === [I] GID do grupo docker no host (Linux/WSL2) ============================
# Descobrir: getent group docker | cut -d: -f3
# Docker Desktop (Win/macOS): irrelevante.
DOCKER_GID=999

# === [I] Grafana =============================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_change_me

# === [I] Firebird bundled (cenario A) ========================================
# Apenas quando o cliente nao tem Firebird Server e a Shift sobe FB 2.5/3.0
# em container. Para servidores remotos, irrelevante.
# Convencao Shift: Windows=C:/Shift/Data, Linux=/opt/shift/data.
# Detalhes: docs/firebird-deployment.md
FIREBIRD_LEGACY_DATA_DIR=C:/Shift/Data
FIREBIRD_LEGACY_PASSWORD=masterkey
