# shift-frontend — variaveis para rodar o frontend STANDALONE (sem Docker).
#
# IMPORTANTE: este arquivo SO e usado quando voce roda `pnpm dev` ou
# `pnpm start` direto. No fluxo Docker Compose, NEXT_PUBLIC_API_BASE_URL
# vem do .env da raiz, propagado via build-arg para a imagem
# (variaveis NEXT_PUBLIC_* sao "burned" no build do Next).
#
# Workflow standalone:
#   cp .env.example .env.local       # .env.local e a convencao do Next.js
#   # editar
#   pnpm dev

# Backend API base URL — incluir o sufixo /api/v1.
# Em dev local: http://localhost:8000/api/v1
# Em deploy: https://api.seu-dominio.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
