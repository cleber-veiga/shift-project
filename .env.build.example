# ============================================================================
# PROPOSITO:    Segredos OFICIAIS embutidos na imagem do backend no build.
# AUDIENCIA:    Cleber (e CI da Shift, no futuro).
# LIDO POR:     scripts/build-and-publish.sh (passa como --build-arg).
# ARQUIVO REAL: .env.build (gitignore).
#
# Visao geral de TODOS os arquivos .env*: docs/configuration.md
# Detalhes do build:                       BUILD-AND-PUBLISH.md
# ============================================================================
#
# As chaves abaixo sao IGUAIS para todos os clientes (chaves da Shift). Vao
# para /etc/shift/embedded.env dentro da imagem. Cliente nunca ve nem edita.
#
# Workflow:
#   cp .env.build.example .env.build
#   # editar .env.build com as chaves reais
#   bash scripts/build-and-publish.sh
#
# ATENCAO: faca backup das chaves em password manager. Se o repo Docker
# Hub for PUBLICO, qualquer um que faca `docker pull` extrai estes valores
# do filesystem da imagem — torne o repo privado ou use chaves dedicadas
# com rate-limit baixo.

# === LLM (Anthropic / OpenAI / etc) ==========================================
# Formato LiteLLM. https://console.anthropic.com -> API Keys
LLM_API_KEY=sk-ant-...

# === Modelo de raciocinio profundo (opcional) ================================
# Habilita o toggle "Pensamento profundo" no chat do SQL Assistant. Vazio
# desliga a feature na UI. Exemplos:
#   openai/o4-mini, openai/o3-mini, anthropic/claude-opus-4-5
LLM_REASONING_MODEL=

# === Google OAuth (botao "Login com Google" no frontend) =====================
# https://console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# === Resend (envio de emails de convite/reset) ===============================
# https://resend.com -> API Keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@shift.app

# === LangSmith (observabilidade — opcional) ==================================
# Deixe vazio se nao for usar tracing de LLM.
# https://smith.langchain.com -> Settings -> API Keys
LANGSMITH_API_KEY=
